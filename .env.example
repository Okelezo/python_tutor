# Copy to .env for local development (DO NOT commit .env)

# Web server
PYTUTOR_PORT=8010
PYTUTOR_HOST=127.0.0.1

# For HTTPS deployments (Railway), set to 1 so cookies are Secure
# PYTUTOR_COOKIE_SECURE=1

# Persistent DB path (recommended for Railway with a mounted volume)
# PYTUTOR_DB_PATH=/data/pytutor.db

# Optional additional protection for deployments
# PYTUTOR_BASIC_AUTH_USER=youruser
# PYTUTOR_BASIC_AUTH_PASS=your-strong-password

# AI provider configuration (BYOK: users provide their own key in the UI)
PYTUTOR_AI_BASE_URL=https://api.openai.com/v1
PYTUTOR_AI_MODEL=gpt-4o-mini
